# --- Firebase ---
# Firebase Console -> Project Settings -> General -> Your apps -> Web app config'den alin
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Sanity ---
# https://www.sanity.io/manage -> Projeniz -> Project ID
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
# Public read icin token gerekmez. Sadece preview/draft icin doldurun.
VITE_SANITY_TOKEN=

# --- Bayi Ayarlari ---
# Bayi indirimi (0.10 = %10)
VITE_DEALER_DISCOUNT=0.10
# Bayi adet adimi (10 = 10, 20, 30...)
VITE_DEALER_QTY_STEP=10
